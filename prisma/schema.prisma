generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LedgerEntryType {
  credit
  debit
  lock
  release
  settleLoss
  settleWin
  refund
}

enum GameRoundStatus {
  open
  settled
  refunded
}

enum GameRoundEventType {
  started
  action
  outcome
  settled
  refunded
}

enum ProvablyFairSeedStatus {
  committed
  revealed
}

enum RiskSeverity {
  low
  medium
  high
  critical
}

enum RiskEventStatus {
  open
  reviewed
  dismissed
}

enum BonusCampaignType {
  welcome
  daily
  cashback
  freeSpins
}

enum BonusClaimStatus {
  claimed
  rejected
}

enum NotificationType {
  system
  bonus
  wallet
  risk
  support
  admin
}

enum UserRole {
  user
  admin
}

enum AiEventCategory {
  page
  game
  wallet
  bonus
  risk
  admin
  session
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  username          String    @unique
  passwordHash      String?
  role              UserRole  @default(user)
  displayName       String?
  dateOfBirth       DateTime?
  ageGateAcceptedAt DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  wallet        Wallet?
  ledgerEntries WalletLedgerEntry[]
  gameRounds    GameRound[]
  authSessions  AuthSession[]
  riskEvents    RiskEvent[]
  bonusClaims   BonusClaim[]
  notifications Notification[]
  aiEvents      AiEvent[]
  aiDecisionExplanations AiDecisionExplanation[]
  aiModelControls AiModelControl[]
  aiFeatureSnapshots AiFeatureSnapshot[]
  churnScores   ChurnScore[]
  fraudScores   FraudScore[]
  responsiblePlayInterventions ResponsiblePlayIntervention[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries NotificationDelivery[]
  tournamentEntries TournamentEntry[]
  tournamentPayouts TournamentPayout[]
  tournamentRefunds TournamentRefund[]
  provablyFairSeeds ProvablyFairSeed[]
  provablyFairSeedNonces ProvablyFairSeedNonce[]
  idempotencyRequests IdempotencyRequest[]
  subjectComplianceCases ComplianceCase[] @relation("ComplianceCaseSubject")
  assignedComplianceCases ComplianceCase[] @relation("ComplianceCaseAssignee")
  complianceCaseNotes ComplianceCaseNote[] @relation("ComplianceCaseNoteAuthor")

  @@map("users")
}

model ComplianceCase {
  id               String   @id @default(cuid())
  subjectUserId    String
  type             String
  status           String   @default("open")
  priority         String   @default("medium")
  title            String
  description      String?
  evidence         Json?
  assignedToUserId String?
  outcome          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  closedAt         DateTime?

  subject    User @relation("ComplianceCaseSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("ComplianceCaseAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  notes      ComplianceCaseNote[]

  @@index([subjectUserId, createdAt])
  @@index([status, priority, createdAt])
  @@index([type, createdAt])
  @@map("compliance_cases")
}

model ComplianceCaseNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String
  note      String
  action    String
  status    String?
  outcome   String?
  evidence  Json?
  createdAt DateTime @default(now())

  case   ComplianceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation("ComplianceCaseNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([authorId, createdAt])
  @@map("compliance_case_notes")
}

model AiModelControl {
  id          String   @id @default(cuid())
  userId      String?
  modelKey    String   @unique
  disabled    Boolean  @default(false)
  reason      String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([disabled, updatedAt])
  @@map("ai_model_controls")
}

model AiDecisionExplanation {
  id                      String   @id @default(cuid())
  userId                  String
  decisionType            String
  modelVersion            String
  sourceRecordId          String?
  sourceFeatureSnapshotId String?
  sourceFeatureVersion    String?
  inputFeatures           Json?
  output                  Json?
  threshold               Json?
  reasonCodes             String[]
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([decisionType, createdAt])
  @@map("ai_decision_explanations")
}

model ResponsiblePlayIntervention {
  id                      String   @id @default(cuid())
  userId                  String
  version                 String
  level                   String
  score                   Int
  reasonCodes             String[]
  recommendedActions      String[]
  message                 String
  requiresAcknowledgement Boolean  @default(false)
  triggerGameId           String?
  triggerStake            BigInt?
  sourceFeatureSnapshotId String?
  sourceFeatureVersion    String?
  details                 Json?
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([level, score, createdAt])
  @@map("responsible_play_interventions")
}

model FraudScore {
  id                      String   @id @default(cuid())
  userId                  String
  version                 String
  score                   Int
  band                    String
  reasonCodes             String[]
  recommendedActions      String[]
  sourceFeatureSnapshotId String?
  sourceFeatureVersion    String?
  details                 Json?
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([band, score, createdAt])
  @@map("fraud_scores")
}

model ChurnScore {
  id                      String   @id @default(cuid())
  userId                  String
  version                 String
  score                   Int
  band                    String
  reasonCodes             String[]
  recommendedActions      String[]
  sourceFeatureSnapshotId String?
  sourceFeatureVersion    String?
  details                 Json?
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([band, score, createdAt])
  @@map("churn_scores")
}

model AiFeatureSnapshot {
  id               String   @id @default(cuid())
  userId           String
  version          String
  sourceEventCount Int      @default(0)
  features         Json
  windowStartedAt  DateTime?
  windowEndedAt    DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, version, createdAt])
  @@map("ai_feature_snapshots")
}

model AiEvent {
  id        String          @id @default(cuid())
  userId    String
  category  AiEventCategory
  name      String
  context   Json?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@map("ai_events")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, enabled])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id                 String           @id @default(cuid())
  userId             String
  notificationId     String?
  type               NotificationType
  channel            String
  status             String
  reason             String?
  preferenceSnapshot Json?
  createdAt          DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([notificationId])
  @@index([status, createdAt])
  @@map("notification_deliveries")
}

model BonusCampaign {
  id          String            @id
  type        BonusCampaignType
  title       String
  description String?
  amount      BigInt            @default(0)
  metadata    Json?
  active      Boolean           @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  claims BonusClaim[]

  @@index([active, type])
  @@map("bonus_campaigns")
}

model BonusClaim {
  id             String           @id @default(cuid())
  userId         String
  campaignId     String
  amount         BigInt
  status         BonusClaimStatus @default(claimed)
  claimKey       String
  idempotencyKey String           @unique
  ledgerEntryId  String?
  metadata       Json?
  createdAt      DateTime         @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign BonusCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId, claimKey])
  @@index([userId, createdAt])
  @@map("bonus_claims")
}

model TournamentEntry {
  id             String   @id @default(cuid())
  tournamentId   String
  userId         String
  entryFee       BigInt
  ledgerEntryId  String?
  idempotencyKey String   @unique
  enteredAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  refund TournamentRefund?

  @@unique([tournamentId, userId])
  @@index([userId, enteredAt])
  @@index([tournamentId, enteredAt])
  @@map("tournament_entries")
}

model TournamentSettlement {
  id             String   @id @default(cuid())
  tournamentId   String   @unique
  prizePool      BigInt
  status         String   @default("settled")
  idempotencyKey String   @unique
  settledAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  payouts TournamentPayout[]

  @@index([settledAt])
  @@map("tournament_settlements")
}

model TournamentPayout {
  id             String   @id @default(cuid())
  settlementId   String
  tournamentId   String
  userId         String
  rank           Int
  amount         BigInt
  ledgerEntryId  String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  settlement TournamentSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, rank])
  @@index([userId, createdAt])
  @@index([tournamentId, rank])
  @@map("tournament_payouts")
}

model TournamentCancellation {
  id             String   @id @default(cuid())
  tournamentId   String   @unique
  reason         String
  idempotencyKey String   @unique
  cancelledAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  refunds TournamentRefund[]

  @@index([cancelledAt])
  @@map("tournament_cancellations")
}

model TournamentRefund {
  id             String   @id @default(cuid())
  cancellationId String
  tournamentId   String
  entryId        String   @unique
  userId         String
  amount         BigInt
  ledgerEntryId  String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  cancellation TournamentCancellation @relation(fields: [cancellationId], references: [id], onDelete: Cascade)
  entry        TournamentEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, entryId])
  @@index([userId, createdAt])
  @@index([tournamentId, createdAt])
  @@map("tournament_refunds")
}

model RiskEvent {
  id        String          @id @default(cuid())
  userId    String?
  type      String
  severity  RiskSeverity
  status    RiskEventStatus @default(open)
  score     Int             @default(0)
  context   Json?
  createdAt DateTime        @default(now())
  reviewedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, severity, createdAt])
  @@map("risk_events")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  available BigInt   @default(0)
  locked    BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries WalletLedgerEntry[]

  @@map("wallets")
}

model WalletLedgerEntry {
  id             String          @id @default(cuid())
  transactionId  String          @unique
  idempotencyKey String          @unique
  userId         String
  walletId       String
  type           LedgerEntryType
  amount         BigInt
  balanceBefore  BigInt
  balanceAfter   BigInt
  lockedBefore   BigInt
  lockedAfter    BigInt
  gameId         String?
  roundId        String?
  metadata       Json?
  status         String          @default("posted")
  createdAt      DateTime        @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  round  GameRound?  @relation(fields: [roundId], references: [id])

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([roundId])
  @@map("wallet_ledger_entries")
}

model GameRound {
  id                       String          @id @default(cuid())
  userId                   String
  gameId                   String
  stake                    BigInt
  status                   GameRoundStatus @default(open)
  payout                   BigInt          @default(0)
  outcome                  Json?
  lockIdempotencyKey       String          @unique
  settlementIdempotencyKey String?         @unique
  createdAt                DateTime        @default(now())
  settledAt                DateTime?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        GameRoundEvent[]
  ledgerEntries WalletLedgerEntry[]
  provablyFairSeeds ProvablyFairSeed[]

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
  @@index([status])
  @@map("game_rounds")
}

model IdempotencyRequest {
  id             String   @id @default(cuid())
  userId         String
  scope          String
  idempotencyKey String
  fingerprint    String
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, idempotencyKey])
  @@index([userId, createdAt])
  @@index([scope, createdAt])
  @@map("idempotency_requests")
}

model ProvablyFairSeed {
  id             String                   @id @default(cuid())
  userId         String
  gameId         String
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int
  status         ProvablyFairSeedStatus   @default(committed)
  commitmentKey  String                   @unique
  roundId        String?
  committedAt    DateTime                 @default(now())
  revealedAt     DateTime?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  round GameRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@unique([userId, gameId, nonce])
  @@index([userId, committedAt])
  @@index([gameId, committedAt])
  @@index([status])
  @@index([roundId])
  @@map("provably_fair_seeds")
}

model ProvablyFairSeedNonce {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  nextNonce Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("provably_fair_seed_nonces")
}

model GameRoundEvent {
  id        String             @id @default(cuid())
  roundId   String
  type      GameRoundEventType
  payload   Json?
  createdAt DateTime           @default(now())

  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, createdAt])
  @@map("game_round_events")
}
