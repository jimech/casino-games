generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LedgerEntryType {
  credit
  debit
  lock
  release
  settleLoss
  settleWin
  refund
}

enum GameRoundStatus {
  open
  settled
  refunded
}

enum GameRoundEventType {
  started
  action
  outcome
  settled
  refunded
}

enum RiskSeverity {
  low
  medium
  high
  critical
}

enum RiskEventStatus {
  open
  reviewed
  dismissed
}

enum BonusCampaignType {
  welcome
  daily
  cashback
  freeSpins
}

enum BonusClaimStatus {
  claimed
  rejected
}

enum NotificationType {
  system
  bonus
  wallet
  risk
  support
  admin
}

enum UserRole {
  user
  admin
}

enum AiEventCategory {
  page
  game
  wallet
  bonus
  risk
  admin
  session
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  username          String    @unique
  passwordHash      String?
  role              UserRole  @default(user)
  displayName       String?
  dateOfBirth       DateTime?
  ageGateAcceptedAt DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  wallet        Wallet?
  ledgerEntries WalletLedgerEntry[]
  gameRounds    GameRound[]
  authSessions  AuthSession[]
  riskEvents    RiskEvent[]
  bonusClaims   BonusClaim[]
  notifications Notification[]
  aiEvents      AiEvent[]
  aiFeatureSnapshots AiFeatureSnapshot[]

  @@map("users")
}

model AiFeatureSnapshot {
  id               String   @id @default(cuid())
  userId           String
  version          String
  sourceEventCount Int      @default(0)
  features         Json
  windowStartedAt  DateTime?
  windowEndedAt    DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, version, createdAt])
  @@map("ai_feature_snapshots")
}

model AiEvent {
  id        String          @id @default(cuid())
  userId    String
  category  AiEventCategory
  name      String
  context   Json?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@map("ai_events")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model BonusCampaign {
  id          String            @id
  type        BonusCampaignType
  title       String
  description String?
  amount      BigInt            @default(0)
  metadata    Json?
  active      Boolean           @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  claims BonusClaim[]

  @@index([active, type])
  @@map("bonus_campaigns")
}

model BonusClaim {
  id             String           @id @default(cuid())
  userId         String
  campaignId     String
  amount         BigInt
  status         BonusClaimStatus @default(claimed)
  claimKey       String
  idempotencyKey String           @unique
  ledgerEntryId  String?
  metadata       Json?
  createdAt      DateTime         @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign BonusCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId, claimKey])
  @@index([userId, createdAt])
  @@map("bonus_claims")
}

model RiskEvent {
  id        String          @id @default(cuid())
  userId    String?
  type      String
  severity  RiskSeverity
  status    RiskEventStatus @default(open)
  score     Int             @default(0)
  context   Json?
  createdAt DateTime        @default(now())
  reviewedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, severity, createdAt])
  @@map("risk_events")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  available BigInt   @default(0)
  locked    BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries WalletLedgerEntry[]

  @@map("wallets")
}

model WalletLedgerEntry {
  id             String          @id @default(cuid())
  transactionId  String          @unique
  idempotencyKey String          @unique
  userId         String
  walletId       String
  type           LedgerEntryType
  amount         BigInt
  balanceBefore  BigInt
  balanceAfter   BigInt
  lockedBefore   BigInt
  lockedAfter    BigInt
  gameId         String?
  roundId        String?
  metadata       Json?
  status         String          @default("posted")
  createdAt      DateTime        @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  round  GameRound?  @relation(fields: [roundId], references: [id])

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([roundId])
  @@map("wallet_ledger_entries")
}

model GameRound {
  id                       String          @id @default(cuid())
  userId                   String
  gameId                   String
  stake                    BigInt
  status                   GameRoundStatus @default(open)
  payout                   BigInt          @default(0)
  outcome                  Json?
  lockIdempotencyKey       String          @unique
  settlementIdempotencyKey String?         @unique
  createdAt                DateTime        @default(now())
  settledAt                DateTime?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        GameRoundEvent[]
  ledgerEntries WalletLedgerEntry[]

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
  @@index([status])
  @@map("game_rounds")
}

model GameRoundEvent {
  id        String             @id @default(cuid())
  roundId   String
  type      GameRoundEventType
  payload   Json?
  createdAt DateTime           @default(now())

  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, createdAt])
  @@map("game_round_events")
}
