{
  "name": "casino-games",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "clean": "rm -rf dist server.js",
    "db:generate": "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 PRISMA_ENGINES_CACHE_DIR=.prisma-cache prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:validate": "DATABASE_URL=postgresql://user:password@localhost:5432/casino_games prisma validate",
    "db:seed": "tsx prisma/seed.ts",
    "smoke:prisma": "tsx scripts/smoke-prisma.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:backend": "vitest run src/backend",
    "test:math": "vitest run src/domain"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
